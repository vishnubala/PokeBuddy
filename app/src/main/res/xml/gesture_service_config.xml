<?xml version="1.0" encoding="utf-8"?>
<!--
  Deliberately minimal. We request gesture dispatch and window-state events only:
  no content retrieval, no key filtering, no text observation. The service reads
  nothing from other apps — screen understanding comes from our own MediaProjection
  capture, not from the accessibility tree.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:canPerformGestures="true"
    android:notificationTimeout="100"
    android:packageNames="com.nianticlabs.pokemongo"
    android:description="@string/gesture_service_description" />
